{
  "name": "gohan",
  "version": "0.1.0",
  "private": true,
  "description": "Runtime control plane for long-running agents and browser workers",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Scott1015/gohan",
  "bugs": {
    "url": "https://github.com/Scott1015/gohan/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Scott1015/gohan.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/contracts packages/core apps/control-plane services/browser-worker",
    "demo": "bash ./scripts/demo-control-plane.sh",
    "demo:control-plane": "bash ./scripts/demo-control-plane.sh",
    "demo:joint": "bash ./scripts/demo-control-plane-probe-bridge.sh",
    "demo:record": "bash ./scripts/record-demo-control-plane-probe-bridge.sh",
    "demo:gif": "bash ./scripts/render-demo-gif.sh",
    "check:release": "./scripts/check-release.sh",
    "typecheck": "tsc -b packages/contracts packages/core apps/control-plane services/browser-worker --pretty false",
    "test": "npm run build && node --test packages/core/dist/*.test.js apps/control-plane/dist/*.test.js services/browser-worker/dist/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
